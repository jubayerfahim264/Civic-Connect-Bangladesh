rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {

      // allow authenticated user to create their document
      allow create: if request.auth != null;

      // allow user to read/update only their own data
      allow read, update: if request.auth != null && request.auth.uid == userId;

      // prevent delete
      allow delete: if false;
    }

    // public services can be read by anyone, authenticated or not
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) &&
      get(/databases/$(database)/documents/users/$(uid)).data.role == "admin";
    }

    // open blog collections for public viewing
    match /blogs/{postId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /blogCategories/{catId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

  }
}